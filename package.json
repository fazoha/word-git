{
  "name": "spellbook-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "collab": "npm run start --prefix server",
    "dev:full": "concurrently -k \"npm run collab\" \"vite\"",
    "dev:double": "concurrently -k -n collab,i1,i2 -c blue,green,yellow \"npm run collab\" \"npm run dev -- --port 5174 --strictPort\" \"npm run dev -- --port 5175 --strictPort\"",
    "dev:triple": "concurrently -k -n collab,i1,i2,i3 -c blue,green,yellow,magenta \"npm run collab\" \"npm run dev -- --port 5174 --strictPort\" \"npm run dev -- --port 5175 --strictPort\" \"npm run dev -- --port 5176 --strictPort\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "diff": "^8.0.4",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.11"
  }
}
